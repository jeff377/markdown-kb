@page
@model MarkdownKB.Web.Pages.ChatModel
@{
    ViewData["Title"] = "問答";
}

<style>
    /* ── layout ── */
    .chat-wrap {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 52px - 3rem); /* full height minus header & padding */
        max-width: 860px;
        margin: 0 auto;
    }
    .chat-toolbar {
        display: flex;
        gap: .5rem;
        align-items: center;
        margin-bottom: .75rem;
        flex-wrap: wrap;
    }
    .chat-toolbar select { width: 220px; }
    .chat-toolbar .btn-new { margin-left: auto; }

    /* ── message list ── */
    .chat-messages {
        flex: 1;
        overflow-y: auto;
        border: 1px solid #d0d7de;
        border-radius: 8px;
        padding: 1rem;
        background: #fff;
        display: flex;
        flex-direction: column;
        gap: .75rem;
    }
    .msg { display: flex; flex-direction: column; max-width: 82%; }
    .msg.user  { align-self: flex-end; align-items: flex-end; }
    .msg.assistant { align-self: flex-start; }

    .msg-bubble {
        padding: .6rem .9rem;
        border-radius: 12px;
        font-size: .9rem;
        line-height: 1.6;
        white-space: pre-wrap;
        word-break: break-word;
    }
    .msg.user      .msg-bubble { background: #0969da; color: #fff; border-bottom-right-radius: 3px; }
    .msg.assistant .msg-bubble { background: #f6f8fa; border: 1px solid #d0d7de; border-bottom-left-radius: 3px; }

    /* ── citations ── */
    .citations { margin-top: .4rem; display: flex; flex-wrap: wrap; gap: .3rem; }
    .citation-pill {
        font-size: .75rem;
        padding: .15rem .5rem;
        border-radius: 10px;
        background: #ddf4ff;
        border: 1px solid #54aeff;
        color: #0969da;
        text-decoration: none;
    }
    .citation-pill:hover { background: #b6e3ff; }

    /* ── input bar ── */
    .chat-input-bar {
        display: flex;
        gap: .5rem;
        margin-top: .75rem;
    }
    .chat-input-bar textarea {
        flex: 1;
        resize: none;
        border-radius: 8px;
        padding: .6rem .9rem;
        font-size: .9rem;
        border: 1px solid #d0d7de;
        height: 52px;
        max-height: 120px;
        overflow-y: auto;
    }
    .chat-input-bar textarea:focus { outline: none; border-color: #0969da; }
    .chat-input-bar .btn-send {
        width: 52px;
        height: 52px;
        border-radius: 8px;
        border: none;
        background: #0969da;
        color: #fff;
        font-size: 1.2rem;
        cursor: pointer;
        flex-shrink: 0;
    }
    .chat-input-bar .btn-send:disabled { background: #8dc5fb; cursor: not-allowed; }

    /* ── thinking indicator ── */
    .thinking-dots span {
        display: inline-block;
        width: 6px; height: 6px;
        border-radius: 50%;
        background: #57606a;
        margin: 0 2px;
        animation: blink 1.2s infinite;
    }
    .thinking-dots span:nth-child(2) { animation-delay: .2s; }
    .thinking-dots span:nth-child(3) { animation-delay: .4s; }
    @@keyframes blink { 0%,80%,100% { opacity:.2 } 40% { opacity:1 } }

    /* ── empty state ── */
    .chat-empty {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #57606a;
        font-size: .9rem;
        gap: .5rem;
    }
</style>

<div class="chat-wrap">

    <!-- Toolbar -->
    <div class="chat-toolbar">
        <label class="form-label mb-0 small fw-semibold">Repo：</label>
        <select id="repo-filter" class="form-select form-select-sm">
            <option value="">全部 Repo</option>
            @foreach (var r in Model.AvailableRepos)
            {
                <option value="@r">@r</option>
            }
        </select>
        <button id="btn-new" class="btn btn-sm btn-outline-secondary btn-new">＋ 新對話</button>
    </div>

    <!-- Message list -->
    <div class="chat-messages" id="chat-messages">
        <div class="chat-empty" id="chat-empty">
            <span style="font-size:2rem">💬</span>
            <span>請輸入問題，我將根據知識庫內容回答</span>
        </div>
    </div>

    <!-- Input bar -->
    <div class="chat-input-bar">
        <textarea id="chat-input" placeholder="輸入問題… (Enter 送出，Shift+Enter 換行)"></textarea>
        <button class="btn-send" id="btn-send" title="送出">↑</button>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const messagesEl = document.getElementById('chat-messages');
    const emptyEl    = document.getElementById('chat-empty');
    const inputEl    = document.getElementById('chat-input');
    const sendBtn    = document.getElementById('btn-send');
    const repoFilter = document.getElementById('repo-filter');
    const newBtn     = document.getElementById('btn-new');

    let sessionId = null;
    let isBusy    = false;

    // ── Send on Enter (Shift+Enter = newline) ──────────────────────────────
    inputEl.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
    });
    sendBtn.addEventListener('click', sendMessage);
    newBtn.addEventListener('click', newConversation);

    // ── New conversation ───────────────────────────────────────────────────
    function newConversation() {
        if (sessionId) {
            fetch(`/api/chat/${sessionId}`, { method: 'DELETE' }).catch(() => {});
        }
        sessionId = null;
        messagesEl.innerHTML = '';
        messagesEl.appendChild(emptyEl);
        emptyEl.style.display = 'flex';
        inputEl.focus();
    }

    // ── Send message ───────────────────────────────────────────────────────
    async function sendMessage() {
        const text = inputEl.value.trim();
        if (!text || isBusy) return;

        isBusy = true;
        sendBtn.disabled = true;
        inputEl.value = '';
        inputEl.style.height = '52px';

        // Hide empty state
        emptyEl.style.display = 'none';

        // Render user bubble
        appendBubble('user', text);

        // Render thinking indicator
        const thinkingId = appendThinking();

        try {
            const res = await fetch('/api/chat', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({
                    message:   text,
                    sessionId: sessionId,
                    repo:      repoFilter.value || null
                })
            });

            removeThinking(thinkingId);

            if (!res.ok) {
                appendBubble('assistant', '⚠️ 發生錯誤，請稍後再試。');
            } else {
                const data = res.ok ? await res.json() : null;
                sessionId = data.sessionId;
                appendAnswer(data.answer, data.citations);
            }
        } catch {
            removeThinking(thinkingId);
            appendBubble('assistant', '⚠️ 連線失敗，請稍後再試。');
        }

        isBusy = false;
        sendBtn.disabled = false;
        inputEl.focus();
    }

    // ── Render helpers ─────────────────────────────────────────────────────
    function appendBubble(role, text) {
        const msg    = document.createElement('div');
        msg.className = `msg ${role}`;
        const bubble  = document.createElement('div');
        bubble.className = 'msg-bubble';
        bubble.textContent = text;
        msg.appendChild(bubble);
        messagesEl.appendChild(msg);
        scrollToBottom();
        return msg;
    }

    function appendAnswer(text, citations) {
        const msg    = document.createElement('div');
        msg.className = 'msg assistant';

        const bubble = document.createElement('div');
        bubble.className = 'msg-bubble';
        bubble.textContent = text;
        msg.appendChild(bubble);

        if (citations && citations.length > 0) {
            const pills = document.createElement('div');
            pills.className = 'citations';
            citations.forEach(c => {
                const a = document.createElement('a');
                a.className = 'citation-pill';
                a.href      = c.viewerUrl;
                a.title     = c.headingPath
                    ? `${c.filePath} › ${c.headingPath}`
                    : c.filePath;
                a.textContent = `[${c.index}] ${shortName(c.filePath)}`;
                pills.appendChild(a);
            });
            msg.appendChild(pills);
        }

        messagesEl.appendChild(msg);
        scrollToBottom();
    }

    function appendThinking() {
        const id  = `thinking-${Date.now()}`;
        const msg = document.createElement('div');
        msg.className = 'msg assistant';
        msg.id = id;
        msg.innerHTML = `<div class="msg-bubble thinking-dots">
            <span></span><span></span><span></span></div>`;
        messagesEl.appendChild(msg);
        scrollToBottom();
        return id;
    }

    function removeThinking(id) {
        document.getElementById(id)?.remove();
    }

    function scrollToBottom() {
        messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function shortName(filePath) {
        const parts = filePath.split('/');
        return parts[parts.length - 1].replace('.md', '');
    }

    // ── Auto-resize textarea ───────────────────────────────────────────────
    inputEl.addEventListener('input', () => {
        inputEl.style.height = '52px';
        inputEl.style.height = Math.min(inputEl.scrollHeight, 120) + 'px';
    });

    inputEl.focus();
})();
</script>
}
