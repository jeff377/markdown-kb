<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MarkdownKB</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github.min.css"
          crossorigin="anonymous" />
    <style>
        html, body { height: 100%; }
        body { display: flex; flex-direction: column; overflow: hidden; }

        /* ── header ── */
        .site-header {
            height: 52px;
            background: #24292f;
            color: #fff;
            display: flex;
            align-items: center;
            padding: 0 1rem;
            gap: 1rem;
            flex-shrink: 0;
        }
        .site-header a { color: #cdd9e5; text-decoration: none; font-size: .85rem; }
        .site-header a:hover { color: #fff; }
        .site-header .repo-name { font-weight: 600; font-size: 1rem; color: #fff; }

        /* ── main row ── */
        .main-row { display: flex; flex: 1; overflow: hidden; }

        /* ── sidebar ── */
        .sidebar {
            width: 280px;
            flex-shrink: 0;
            overflow-y: auto;
            background: #f6f8fa;
            border-right: 1px solid #d0d7de;
            padding: .75rem .5rem;
        }

        /* ── content ── */
        .content-area { flex: 1; overflow-y: auto; padding: 1.5rem 2rem; }

        /* ── loading overlay ── */
        #loading-overlay {
            position: fixed;
            inset: 0;
            background: rgba(255, 255, 255, .75);
            z-index: 9999;
            display: none;
            align-items: center;
            justify-content: center;
        }
        #loading-overlay.active { display: flex; }
    </style>
</head>
<body>
    <!-- Loading spinner overlay (shown during page navigation) -->
    <div id="loading-overlay" role="status" aria-label="載入中">
        <div class="text-center">
            <div class="spinner-border text-primary" style="width:2.5rem;height:2.5rem;"></div>
            <div class="mt-2 small text-muted">載入中…</div>
        </div>
    </div>

    <!-- header -->
    <header class="site-header">
        <a href="/">← 返回首頁</a>
        @if (ViewData["Repo"] is string repoName && !string.IsNullOrEmpty(repoName))
        {
            <span class="repo-name">@(ViewData["Owner"])/@repoName</span>
        }
        <a href="/Chat" style="margin-left:auto;">💬 問答</a>
        <a href="/Search">🔍 搜尋</a>
        <a href="/Admin/Reindex">⚙️ 管理</a>
    </header>

    <!-- two-column body -->
    <div class="main-row">
        @if (ViewData["Tree"] != null)
        {
            <nav class="sidebar">
                @await Html.PartialAsync("_TreeNav")
            </nav>
        }
        <main class="content-area">
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmHEA6bEPD4IpFl2+j/zR1JObYa"
            crossorigin="anonymous"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"
            crossorigin="anonymous"></script>
    <script>
        hljs.highlightAll();

        // Show loading overlay on navigation
        (function () {
            var overlay = document.getElementById('loading-overlay');
            function show() { overlay.classList.add('active'); }

            window.addEventListener('beforeunload', show);

            document.addEventListener('click', function (e) {
                var a = e.target.closest('a[href]');
                if (!a) return;
                var href = a.getAttribute('href') || '';
                if (href.startsWith('#') || href.startsWith('javascript') || a.target === '_blank') return;
                show();
            });

            document.addEventListener('submit', show);
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
